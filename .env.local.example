NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# WhatsApp gateway (getsender.id) untuk rekap shift otomatis
WA_API_KEY=your-getsender-api-key
WA_SENDER=62xxxxxxxxxxx

# URL publik aplikasi (untuk link pemesanan online pelanggan)
# Contoh: https://sabana-pos.vercel.app
# Setelah set, link /order akan tampil di Settings > Pesanan Online
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app
